generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model Usuario {
  id           Int    @id @default(autoincrement())
  email        String @unique
  senha_hash   String
  refreshToken String?

  categorias   Categoria[]
  produtos     Produto[]
  movimentacoes Movimentacao[]
}

model Categoria {
  id        Int    @id @default(autoincrement())
  nome      String
  descricao String?

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  produtos  Produto[]
}

model Produto {
  id                 Int    @id @default(autoincrement())
  nome               String
  descricao          String?
  preco              Float
  quantidade_estoque Int @default(0)

  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  movimentacoes Movimentacao[]
}

model Movimentacao {
  id         Int      @id @default(autoincrement())
  tipo       String
  quantidade Int
  data       DateTime @default(now())
  observacao String?

  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id])

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}